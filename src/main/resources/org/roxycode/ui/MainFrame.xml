<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE column-panel SYSTEM "sierra.dtd">

<column-panel opaque="true">

    <menu-bar>
        <menu text="File">
            <menu-item name="openFolderMenuItem" text="Open Folder..."/>
            <menu-item name="settingsMenuItem" text="Settings"/>
            <menu-item name="exitMenuItem" text="Exit"/>
        </menu>
        <menu text="About">
            <menu-item name="aboutMenuItem" text="About RoxyCode"/>
        </menu>
    </menu-bar>

    <row-panel spacing="8" padding="8" opaque="true" alignToBaseline="false">
        <label text="" name="icon"/>
        <label text="RoxyCode" styleClass="h3"/>
        <spacer size="16"/>
        <label text="Project: "/>
        <label text="[PROJECT_NAME]" name="currentProjectLabel"/>
        <label text="Branch:"/>
        <label name="gitBranchLabel" text="unknown" styleClass="monospaced"/>
        <spacer size="16"/>
    </row-panel>

    <row-panel weight="1" alignToBaseline="false">

        <column-panel padding="12" spacing="8" opaque="true">
            <label text="MENU" font="bold-12"/>

            <toggle-button name="navChatButton" text="Chat" borderPainted="false" horizontalAlignment="left" group="navGroup" selected="true"/>
            <toggle-button name="navFilesButton" text="Project Files" borderPainted="false" horizontalAlignment="left" group="navGroup"/>
            <toggle-button name="navUsageButton" text="Usage" borderPainted="false" horizontalAlignment="left" group="navGroup"/>
            <toggle-button name="navSettingsButton" text="Settings" borderPainted="false" horizontalAlignment="left" group="navGroup"/>
            <toggle-button name="navSystemPromptButton" text="System Prompt" borderPainted="false" horizontalAlignment="left" group="navGroup"/>
            <toggle-button name="navMessageHistoryButton" text="Message History" borderPainted="false" horizontalAlignment="left" group="navGroup"/>
            <toggle-button name="navSummaryQueueButton" text="Summary Queue" borderPainted="false" horizontalAlignment="left" group="navGroup"/>

            <spacer weight="1"/>
        </column-panel>

        <stack-panel weight="1" name="mainContentStack">

        </stack-panel>

    </row-panel>
</column-panel>