<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE column-panel SYSTEM "sierra.dtd">

<column-panel opaque="true">

    <row-panel spacing="8" padding="8" opaque="true" alignToBaseline="false" >
        <label text="" name="icon"/>
        <label text="RoxyCode" styleClass="h3"/>
        <spacer size="16"/>
        <label name="currentProjectLabel" text="[PROJECT_NAME]" styleClass="h4"/>
        <spacer size="4"/>
        <label name="gitBranchLabel" text="unknown" foreground="#888888"/>
        <button name="openFolderButton" text="Change Project" borderPainted="false" focusPainted="false" contentAreaFilled="false"/>
        <spacer weight="1"/>
        <label name="roxyModeLabel" text="" style="font: bold"/>
        <activity-indicator name="activityIndicator" indicatorSize="12" visible="false"/>
        <spacer size="16"/>
    </row-panel>

    <row-panel weight="1" alignToBaseline="false">

        <column-panel padding="16" spacing="10" opaque="true">
            <label text="MENU" style="font: bold"/>

            <toggle-button name="navChatButton" text="Chat" borderPainted="false" horizontalAlignment="left"
                           group="navGroup" selected="true"/>
            <toggle-button name="navChangesButton" text="Project Changes" borderPainted="false" horizontalAlignment="left"
                           group="navGroup"/>
            <toggle-button name="navUsageButton" text="Usage" borderPainted="false" horizontalAlignment="left"
                           group="navGroup"/>
            <toggle-button name="navSettingsButton" text="Settings" borderPainted="false" horizontalAlignment="left"
                           group="navGroup"/>
            <toggle-button name="navSystemPromptButton" text="System Prompt" borderPainted="false"
                           horizontalAlignment="left" group="navGroup"/>
            <toggle-button name="navMessageHistoryButton" text="Message History" borderPainted="false"
                           horizontalAlignment="left" group="navGroup"/>
            <toggle-button name="navLogsButton" text="System Logs" borderPainted="false" horizontalAlignment="left"
                           group="navGroup"/>
            <toggle-button name="navCodebaseCacheButton" text="Codebase Cache" borderPainted="false"
                           horizontalAlignment="left" group="navGroup"/>
            <toggle-button name="navGeminiCachesButton" text="Gemini Caches" borderPainted="false"
                           horizontalAlignment="left" group="navGroup"/>

            <spacer weight="1"/>
        </column-panel>

        <column-panel weight="1">
            <row-panel name="notificationBar" spacing="10" padding="10" opaque="true">
                <label name="notificationIcon"/>
                <label name="notificationLabel" weight="1"/>
                <button name="closeNotificationButton" borderPainted="false"/>
            </row-panel>

            <stack-panel weight="1" name="mainContentStack">

            </stack-panel>
        </column-panel>

    </row-panel>
</column-panel>
