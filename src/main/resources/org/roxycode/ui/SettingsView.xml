<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE column-panel SYSTEM "sierra.dtd">

<column-panel name="viewSettings" visible="true" padding="16" spacing="8">
    
    <tabbed-pane weight="1">
        <column-panel tabTitle="Global Settings" spacing="8" padding="16">
            <label text="Gemini API Key:"/>
            <row-panel spacing="8">
                <password-field name="apiKeyField" columns="30" weight="1"/>
            </row-panel>

            <spacer size="8"/>
            <label text="Gemini Model:"/>
            <row-panel spacing="8">
                <combo-box name="modelComboBox" weight="1"/>
            </row-panel>

            <spacer size="8"/>
            <label text="Max Turns (Chat History):"/>
            <row-panel spacing="8">
                <text-field name="maxTurnsField" columns="10"/>
            </row-panel>

            <spacer size="8"/>
            <label text="System Log Lines:"/>
            <row-panel spacing="8">
                <text-field name="logLinesCountField" columns="10"/>
                <check-box name="logAutoScrollCheckBox" text="Auto-scroll Logs" weight="1"/>
            </row-panel>

            <spacer size="8"/>
            <label text="Theme:"/>
            <row-panel spacing="8">
                <combo-box name="themeComboBox" weight="1"/>
            </row-panel>
            <spacer weight="1"/>
        </column-panel>

        <column-panel tabTitle="Memory Compaction" spacing="8" padding="16">
            <label text="History Threshold (Start Compacting at):"/>
            <row-panel spacing="8">
                <text-field name="historyThresholdField" columns="10"/>
            </row-panel>

            <spacer size="8"/>
            <label text="Compaction Chunk Size (Messages to Summarize):"/>
            <row-panel spacing="8">
                <text-field name="compactionChunkSizeField" columns="10"/>
            </row-panel>

            <spacer size="8"/>
            <label text="Max Summary Chunks (Context Segments):"/>
            <row-panel spacing="8">
                <text-field name="maxSummaryChunksField" columns="10"/>
            </row-panel>
            <spacer weight="1"/>
        </column-panel>
    </tabbed-pane>

    <spacer size="8"/>
    <row-panel>
        <button name="saveSettingsButton" text="Save Settings"/>
    </row-panel>
    
</column-panel>