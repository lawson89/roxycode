<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE column-panel SYSTEM "sierra.dtd">

<column-panel name="viewSettings" padding="16" spacing="8">
    
    <tabbed-pane weight="1">
        <column-panel tabTitle="Global Settings" spacing="8" padding="16">
            <label text="Gemini API Key:"/>
            <row-panel spacing="8">
                <password-field name="apiKeyField" columns="30" weight="1"/>
            </row-panel>

            <spacer size="8"/>
            <label text="Gemini Model:"/>
            <row-panel spacing="8">
                <combo-box name="modelComboBox" weight="1"/>
            </row-panel>
            <row-panel spacing="8">
                <label text="Input Price: " font="PLAIN 11"/>
                <label name="modelInputPriceLabel" text="N/A" font="BOLD 11"/>
                <spacer size="16"/>
                <label text="Output Price: " font="PLAIN 11"/>
                <label name="modelOutputPriceLabel" text="N/A" font="BOLD 11"/>
            </row-panel>

            <spacer size="8"/>
            <label text="Max Turns (Chat History):"/>
            <row-panel spacing="8">
                <text-field name="maxTurnsField" columns="10"/>
            </row-panel>

            <spacer size="8"/>
            <label text="System Log Lines:"/>
            <row-panel spacing="8">
                <text-field name="logLinesCountField" columns="10"/>
                <check-box name="logAutoScrollCheckBox" text="Auto-scroll Logs" weight="1"/>
            </row-panel>

            <spacer size="8"/>
            <label text="Theme:"/>
            <row-panel spacing="8">
                <combo-box name="themeComboBox" weight="1"/>
            </row-panel>
            <spacer weight="1"/>
        </column-panel>

        <column-panel tabTitle="Conversation Settings" spacing="8" padding="16">
            <label text="History Window Size:"/>
            <row-panel spacing="8">
                <text-field name="historyWindowSize" columns="10"/>
            </row-panel>
            <spacer weight="1"/>
        </column-panel>

        <column-panel tabTitle="Project Cache" spacing="16" padding="16">
            <check-box name="cacheEnabledCheckBox" text="Enable Project Caching"/>
            
            <column-panel spacing="4">
                <label text="TTL (Time To Live) in Minutes:"/>
                <row-panel spacing="8">
                    <text-field name="cacheTTLField" columns="10"/>
                </row-panel>
                <label text="Cache will expire after this many minutes of inactivity." font="ITALIC 11"/>
            </column-panel>

            <column-panel spacing="4">
                <label text="Minimum Cache Size (Tokens):"/>
                <row-panel spacing="8">
                    <text-field name="cacheMinSizeField" columns="10"/>
                </row-panel>
                <label text="Only requests larger than this will be cached." font="ITALIC 11"/>
            </column-panel>

            <spacer weight="1"/>
        </column-panel>
    </tabbed-pane>

    <spacer size="8"/>
    <row-panel>
        <button name="saveSettingsButton" text="Save Settings"/>
    </row-panel>
    
</column-panel>
