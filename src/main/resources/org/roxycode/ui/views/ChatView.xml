<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE column-panel SYSTEM "sierra.dtd">

<column-panel name="viewChat" weight="1">
    <split-pane name="splitPane" weight="1" resizeWeight="0.7" orientation="vertical">
        <scroll-pane weight="1" horizontalScrollBarPolicy="never" name="chatScrollPane">
        </scroll-pane>
        
        <column-panel weight="1">
            <row-panel spacing="8" padding="4" opaque="true">
                <label text="Attachments:"/>
                <scroll-pane weight="1" verticalScrollBarPolicy="never">
                    <row-panel name="attachmentsContainer" spacing="8"/>
                </scroll-pane>
                <button name="attachButton" text="Attach"/>
                <button name="clearAttachmentsButton" text="Clear"/>
            </row-panel>
            <row-panel spacing="8" padding="12" opaque="true" weight="1">
                <column-panel weight="1" name="inputContainer"/>
                <column-panel spacing="4">
                    <button name="sendButton" text="Send"/>
                    <button name="stopButton" text="Stop" enabled="false"/>
                </column-panel>
            </row-panel>
        </column-panel>
    </split-pane>

    <row-panel spacing="12" padding="2,12,4,12" opaque="true">
        <label name="cacheStatusLabel" text="Cache: Unknown" style="font: -2; foreground: #888888"/>
        <label name="cacheIdLabel" text="" style="font: -2; foreground: #888888"/>
        <label name="cacheExpiryLabel" text="" style="font: -2; foreground: #888888"/>
        <spacer weight="1"/>
        <check-box name="captureTranscriptCheckBox" text="Capture Transcript" style="font: -2"/>
        <button name="planContextButton" text="Plan: None" style="font: -2"/>

        <label name="currentModelLabel" text="[MODEL]" style="font: -2; foreground: #888888"/>
        <label name="msgCountLabel" text="0 Messages" style="font: -2; foreground: #888888"/>
        <label name="inTokenLabel" text="0 In" style="font: -2; foreground: #888888"/>
        <label name="outTokenLabel" text="0 Out" style="font: -2; foreground: #888888"/>
        <spacer weight="1"/>
    </row-panel>
</column-panel>
