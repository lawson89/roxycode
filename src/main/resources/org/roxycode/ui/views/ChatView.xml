<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE column-panel SYSTEM "sierra.dtd">

<column-panel name="viewChat" weight="1">
    <scroll-pane weight="1" horizontalScrollBarPolicy="never" name="chatScrollPane">
    </scroll-pane>
    <row-panel spacing="8" padding="4" opaque="true">
        <label text="Attachments:"/>
        <scroll-pane weight="1" verticalScrollBarPolicy="never">
            <row-panel name="attachmentsContainer" spacing="8"/>
        </scroll-pane>
        <button name="clearAttachmentsButton" text="Clear"/>
    </row-panel>
    <row-panel spacing="4" padding="8" opaque="true">
        <button name="attachButton" text="Attach"/>
        <scroll-pane weight="1">
            <text-area name="inputField" rows="3"/>
        </scroll-pane>
        <button name="sendButton" text="Send"/>
        <button name="stopButton" text="Stop" enabled="false"/>
    </row-panel>
     <row-panel spacing="16" padding="4,12,4,12" opaque="true">
        <spacer weight="1"/>
         <label name="currentModelLabel" size="200,15" text="[MODEL]" styleClass="monospaced"  horizontalAlignment="leading"/>
        <label name="msgCountLabel" size="120,15" text="0 Messages" foreground="#888888"  horizontalAlignment="trailing"/>
        <label name="inTokenLabel" size="100,15" text="0 In" foreground="#888888"  horizontalAlignment="trailing"/>
        <label name="outTokenLabel" size="100, 15" text="0 Out" foreground="#888888" horizontalAlignment="trailing"/>
    </row-panel>
</column-panel>