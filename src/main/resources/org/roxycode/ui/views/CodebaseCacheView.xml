<?xml version="1.0" encoding="UTF-8"?>
<column-panel name="viewCodebaseCache" spacing="10">
    <row-panel spacing="10">
        <column-panel spacing="4" weight="1.0">
            <row-panel spacing="4">
                <label text="Path: " style="font: bold"/>
                <label name="cachePathLabel" text="N/A"/>
            </row-panel>
            <row-panel spacing="4">
                <label text="Last Modified: " style="font: bold"/>
                <label name="cacheLastModifiedLabel" text="N/A"/>
            </row-panel>
            <row-panel spacing="4">
                <label text="Estimated Tokens: " style="font: bold"/>
                <label name="cacheTokenCountLabel" text="0"/>
            </row-panel>
        </column-panel>

        <button name="rebuildCacheButton" text="Rebuild Cache"/>
    </row-panel>

    <row-panel spacing="10">
        <column-panel spacing="4" weight="1.0">
            <row-panel spacing="4">
                <label text="Online Cache ID: " style="font: bold"/>
                <label name="onlineCacheIdLabel" text="Not Pushed"/>
            </row-panel>
            <row-panel spacing="4">
                <label text="Last Pushed: " style="font: bold"/>
                <label name="onlineCacheTimestampLabel" text="-"/>
            </row-panel>
            <row-panel spacing="4">
                <label text="Skeleton Tokens: " style="font: bold"/>
                <label name="skeletonTokenCountLabel" text="0"/>
            </row-panel>
        </column-panel>

        <button name="pushCacheButton" text="Push to Gemini"/>
    </row-panel>

    <scroll-pane name="cacheContentScrollPane" weight="1.0"/>
</column-panel>
